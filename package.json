{
  "name": "@vitriltd/editor-js-govuk-frontend",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Editor.js block tools that render GOV.UK Design System components",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "govuk-editorjs-migrate": "./dist/cli.mjs"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./dist/editor-overrides.css": "./dist/editor-overrides.css"
  },
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "precompile": "tsx scripts/precompile-templates.ts",
    "build": "npm run precompile && vite build",
    "prepublishOnly": "npm run build",
    "dev": "npm run precompile && VITE_DEV=1 vite --config vite.dev.config.ts",
    "build:demo": "npm run precompile && vite build --config vite.dev.config.ts && cp -r node_modules/govuk-frontend/dist/govuk/assets/. demo-dist/assets/",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@editorjs/editorjs": "^2.30.0",
    "@types/node": "^25.2.3",
    "govuk-frontend": "^6.2.0",
    "highlight.js": "^11.11.1",
    "nunjucks": "^3.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vanilla-jsoneditor": "^3.11.0",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@editorjs/editorjs": "^2.x",
    "govuk-frontend": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "govuk-frontend": {
      "optional": true
    }
  }
}
